# App
APP_NAME=Fashion Virus WhatsApp Assistant
APP_ENV=development
DEBUG=true
API_PREFIX=

# Database — PostgreSQL (production) or SQLite (dev)
# PostgreSQL: postgresql+psycopg2://user:pass@localhost:5432/fashion_virus
# SQLite dev:  sqlite:///./data/whatsapp_commerce.db
DATABASE_URL=sqlite:///./data/whatsapp_commerce.db

# Sync from existing Node.js ecommerce SQLite (optional)
NODE_SQLITE_PATH=../backend/data/fashion-virus.db

# Website base URL for product links
WEBSITE_BASE_URL=http://localhost:3000

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# HyperSender WhatsApp API v2
HYPERSENDER_API_KEY=
HYPERSENDER_INSTANCE_ID=
HYPERSENDER_BASE_URL=https://app.hypersender.com/api/whatsapp/v2
HYPERSENDER_WEBHOOK_SECRET=

# AI behaviour
MAX_PRODUCTS_PER_REPLY=3
CACHE_TTL_SECONDS=300
BRAND_NAME=Fashion Virus

# Twilio (AI Calling Agent)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1234567890

# ElevenLabs Conversational AI
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=

# Lead Scoring
LEAD_HOT_THRESHOLD=61
LEAD_WARM_THRESHOLD=31
CALLBACK_COOLDOWN_HOURS=24

# Webhook base URL for callbacks (your public EC2/domain URL)
WEBHOOK_BASE_URL=http://3.108.126.237
